generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url configurada no prisma.config.ts
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum DocumentType {
  PGR
  PCMSO
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  ASO
  CLCB
  RELATORIO_TECNICO
  TLCAT
}

enum DocumentStatus {
  PENDENTE
  EM_ANALISE
  CONCLUIDO
  VENCIDO
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  createdAt DateTime @default(now())

  users     User[]
  documents Document[]
  knowledge CompanyKnowledge[]
  chatMessages ChatMessage[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}

model Document {
  id         String         @id @default(uuid())
  title      String
  type       DocumentType
  status     DocumentStatus @default(PENDENTE)
  fileUrl    String?
  fileName   String?
  aiAnalysis String?        // Resumo da análise da IA
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  companyId  String
  company    Company        @relation(fields: [companyId], references: [id])

  // Pedaços de texto para RAG
  chunks     DocumentChunk[]
}

// Pedaços de texto extraídos dos documentos (para RAG)
model DocumentChunk {
  id         String   @id @default(uuid())
  content    String   // Trecho do texto
  embedding  String?  // Vetor em JSON (para busca semântica)
  chunkIndex Int      // Posição no documento
  createdAt  DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// Perfil acumulado da empresa — aprende com cada documento
model CompanyKnowledge {
  id        String   @id @default(uuid())
  category  String   // Ex: "insalubridade", "periculosidade", "setores", "nrs_aplicaveis"
  content   String   // O conhecimento acumulado em texto
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}

// Histórico do chat da empresa com a IA
model ChatMessage {
  id        String   @id @default(uuid())
  role      String   // "user" ou "assistant"
  content   String
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}
