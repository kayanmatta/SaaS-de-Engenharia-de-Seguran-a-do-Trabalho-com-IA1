generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url configurada no prisma.config.ts
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum DocumentType {
  PGR
  PCMSO
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  ASO
  CLCB
  RELATORIO_TECNICO
  TLCAT
}

enum DocumentStatus {
  PENDENTE
  EM_ANALISE
  CONCLUIDO
  VENCIDO
}

model Company {
  id        String     @id @default(uuid())
  name      String
  cnpj      String?    @unique
  createdAt DateTime   @default(now())

  users     User[]
  documents Document[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}

model Document {
  id         String         @id @default(uuid())
  title      String
  type       DocumentType
  status     DocumentStatus @default(PENDENTE)
  fileUrl    String?
  fileName   String?
  aiAnalysis String?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  companyId  String
  company    Company        @relation(fields: [companyId], references: [id])
}
