generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Remova a linha 'url' daqui, ela será configurada no prisma.config.ts
}

enum Role {
  ADMIN
  USER
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}
