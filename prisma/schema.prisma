generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url configurada no prisma.config.ts
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum DocumentType {
  PGR
  PCMSO
  LAUDO_INSALUBRIDADE
  LAUDO_PERICULOSIDADE
  ASO
  CLCB
  RELATORIO_TECNICO
  TLCAT
}

enum DocumentStatus {
  PENDENTE
  EM_ANALISE
  CONCLUIDO
  VENCIDO
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  createdAt DateTime @default(now())

  users        User[]
  documents    Document[]
  knowledge    CompanyKnowledge[]
  chatMessages ChatMessage[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  companyId String
  // ✅ Se empresa for deletada, usuários são removidos junto
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Document {
  id         String         @id @default(uuid())
  title      String
  type       DocumentType
  status     DocumentStatus @default(PENDENTE)
  fileUrl    String?
  fileName   String?
  aiAnalysis String?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  companyId  String
  // ✅ Se empresa for deletada, documentos são removidos junto
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  chunks     DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(uuid())
  content    String
  embedding  String?
  chunkIndex Int
  createdAt  DateTime @default(now())

  documentId String
  // ✅ Já estava correto — chunk deletado junto com documento
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model CompanyKnowledge {
  id        String   @id @default(uuid())
  category  String
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  companyId String
  // ✅ Se empresa for deletada, knowledge é removido junto
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      String
  content   String
  createdAt DateTime @default(now())

  companyId String
  // ✅ Se empresa for deletada, mensagens são removidas junto
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
